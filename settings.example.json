{
  "embedding": {
    "provider": "auto",
    "apiKey": "${OPENAI_API_KEY}",
    "baseUrl": null,
    "model": "auto",
    "timeout": 30000,
    "maxRetries": 3,
    "batchSize": 50,
    "dimension": 256
  },
  "indexing": {
    "chunkSize": 512,
    "chunkOverlap": 50,
    "generateOnIndex": true,
    "reindexOnDelete": false,
    "followSymlinks": false,
    "maxFileSize": 10485760
  },
  "search": {
    "vectorWeight": 0.7,
    "textWeight": 0.3,
    "rerank": true,
    "minScore": 0.1,
    "limit": 20
  },
  "cache": {
    "embeddingsDir": ".docgraph/embeddings",
    "ttl": 604800,
    "maxCacheSize": 1073741824
  },
  "exclude": {
    "enabled": true,
    "patterns": ["**/secrets/**"],
    "useGitignore": true,
    "useDefaultPatterns": true
  },
  "files": {
    "extensions": [],
    "excludeExtensions": [],
    "maxFileSize": 10485760,
    "includeHidden": false
  },
  "providers": {
    "primary": "auto",
    "fallback": []
  },
  "sources": {
    "sources": {},
    "pullOnIndex": true,
    "pullOnReindex": true,
    "maxPagesPerSource": 50,
    "maxConcurrentSources": 4
  },
  "logging": {
    "level": "info",
    "maxBytes": 5242880,
    "maxFiles": 3,
    "mirrorStderr": false
  },
  "watch": {
    "enabled": true,
    "debounceMs": 1000
  },
  "security": {
    "readOnly": false
  },
  "debug": false
}
